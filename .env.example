# このファイルを .env という名前でコピーして、自分のAPIキーを入力してください
# cp .env.example .env

# ============================================================
# Webアプリ設定
# ============================================================

# Flask/FastAPI セキュリティキー（任意の長いランダム文字列）
# python -c "import secrets; print(secrets.token_hex(32))" で生成
SECRET_KEY=ここにランダム文字列を入れる

# ============================================================
# 気象・海洋API（オプション）
# ============================================================

# WeatherAPI.com 波高取得（オプション・無料プランあり）
# https://www.weatherapi.com/ で取得
WEATHERAPI_KEY=

# 海しる（日本海洋データセンター）API（オプション・試用版）
KAIHO_API_KEY_1=
KAIHO_API_KEY_2=
KAIHO_API_KEY_3=

# ============================================================
# AI機能（オプション）
# ============================================================

# Anthropic Claude API キー
# 設定するとAIによる自然言語アドバイスが追加されます
# https://console.anthropic.com/ で取得できます
ANTHROPIC_API_KEY=
